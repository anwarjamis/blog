<h1>Categorías</h1>
<ul class="list-group">
<% @categories.each do |category| %>
  <li class="list-group-item d-flex justify-content-between align-items-center">
    <strong><%= link_to category.name, category_path(category), class: "text-decoration-none" %></strong>
    <span class="badge badge-primary badge-pill">14</span>
  </li>
<% end %>
</ul>
<br>
<%= link_to 'Nueva categoría', new_category_path, class: "btn btn-primary" %>

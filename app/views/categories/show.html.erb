<h3>Posts de <%= @category.name %></h3>
<ul class="list-group list-group-flush">
<% @category.posts.each do |post|%>
  <li class="list-group-item"><%= link_to post.title, "#{post.medium_url}", class: "text-decoration-none" %></li>
<% end %>
</ul>
<div class="btn-group mt-2">
<%= link_to 'Editar', edit_category_path(@category), class: "btn btn-sm btn-outline-secondary" %>
  <%= link_to 'Borrar categoría', category_path(@category),
                                  method: :delete,
                                  class: "btn btn-sm btn-outline-secondary",
                                  data: { confirm: "Estás seguro que quieres eliminar esta categoría?" } %>
</div>
